<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Pause Before... The Collaboration Journey</title>
<style>
*{box-sizing:border-box;margin:0;padding:0} :root{--cream:#FBF6EC;--ink:#2B2622;--muted:#7A726B;--line:#E8E0D2;--green:#2F6B3A;--gold:#F2A51A;--red:#D94A38;--purple:#7436A8;--blue:#1159A5} body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:radial-gradient(circle at top left,#fffdf7,#FBF6EC 45%,#f7f0e4);color:var(--ink);min-height:100vh;padding:18px}.wrap{max-width:1180px;margin:auto}.top{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-bottom:18px}.brand{display:flex;align-items:center;gap:12px}.logo{width:54px;height:54px;border-radius:18px;background:var(--green);color:white;display:grid;place-items:center;font-size:30px;box-shadow:0 6px 18px rgba(47,107,58,.25)}h1{font-size:2rem;line-height:1}.tag{color:var(--muted);font-size:.92rem;margin-top:5px}.pill{background:white;border:1.5px solid var(--line);border-radius:16px;padding:12px 16px;font-weight:800}.card{background:rgba(255,255,255,.82);border:1.5px solid var(--line);border-radius:22px;padding:24px;margin-bottom:16px;box-shadow:0 8px 28px rgba(43,38,34,.06)}.hidden{display:none!important}.btn{border:0;border-radius:999px;padding:12px 22px;font-weight:900;cursor:pointer;font-family:inherit;font-size:.95rem}.btn-primary{background:var(--ink);color:white}.btn-green{background:var(--green);color:white}.btn-soft{background:var(--cream);border:1.5px solid var(--line);color:var(--ink)}.btn-red{background:#fff0ed;border:1.5px solid #f0b1a7;color:#a92f22}.input{width:100%;padding:14px 16px;border:1.5px solid var(--line);border-radius:14px;font-size:1rem;margin:10px 0 14px}.tabs{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:16px}.tab{background:white;border:1.5px solid var(--line);border-radius:999px;padding:11px 18px;font-weight:900;cursor:pointer}.tab.active{background:var(--green);color:white}.hero{text-align:center}.hero h2{font-size:1.45rem;margin-bottom:8px}.char-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-top:22px}.char-card{display:grid;grid-template-columns:180px 1fr;align-items:center;gap:18px;text-align:left;border:2px solid var(--line);border-radius:22px;padding:18px;background:linear-gradient(135deg,#fff,#fffaf0);cursor:pointer;transition:.2s}.char-card:hover{transform:translateY(-4px);box-shadow:0 12px 28px rgba(0,0,0,.1)}.char-card.casey{border-color:#8d51bd}.char-card.charlie{border-color:#1b65b1}.char-card img{width:180px;height:180px;object-fit:contain}.char-card h3{font-size:1.8rem;margin-bottom:10px}.casey h3{color:#7436A8}.charlie h3{color:#1159A5}.grid-months{display:grid;grid-template-columns:repeat(6,1fr);gap:14px}.month-card{min-height:210px;background:white;border:1.5px solid var(--line);border-radius:18px;padding:16px;text-align:center;position:relative;overflow:hidden}.month-card.available{border-color:var(--gold);box-shadow:0 0 0 3px rgba(242,165,26,.12)}.month-card.done{border-color:var(--green);background:#f4fbf2}.month-card.locked{opacity:.55;filter:grayscale(.8)}.badge{position:absolute;top:0;left:50%;transform:translateX(-50%);font-size:.7rem;font-weight:900;padding:7px 16px;border-radius:0 0 10px 10px;color:white;background:#938b82}.available .badge{background:var(--gold)}.done .badge{background:var(--green)}.month-big{font-size:1.75rem;font-weight:1000;margin-top:26px}.month-card p{font-size:.88rem;line-height:1.35;margin-top:5px}.month-card img{width:86px;height:86px;object-fit:contain;margin:12px auto 0;display:block}.dash{display:grid;grid-template-columns:1.05fr 1.35fr 1fr;gap:16px}.profile{display:flex;gap:14px;align-items:center}.avatar{width:100px;height:100px;object-fit:contain}.bars{display:grid;gap:12px}.bar-row{display:grid;grid-template-columns:150px 1fr 52px;align-items:center;gap:10px;font-size:.9rem}.track{height:12px;background:#eee7dd;border-radius:999px;overflow:hidden}.fill{height:100%;background:var(--green);border-radius:999px}.stamp-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}.stamp{height:64px;border:2px dashed #ead7b9;border-radius:50%;display:grid;place-items:center;text-align:center;font-size:.72rem;font-weight:900;color:#907a55}.stamp.got{border-style:solid;background:#f4fbf2;color:var(--green)}.story-head{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-bottom:18px}.story-box{display:grid;grid-template-columns:160px 1fr;gap:20px;align-items:center}.story-box img{width:160px;height:160px;object-fit:contain}.scene-title{font-size:1.5rem;margin-bottom:8px}.scene-text{font-size:1.08rem;line-height:1.65;color:#3d352f}.choice-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:22px}.choice{border:2px solid var(--line);background:white;border-radius:18px;padding:18px;text-align:left;cursor:pointer;transition:.2s}.choice:hover{border-color:var(--green);transform:translateY(-2px)}.choice b{display:block;margin-bottom:8px}.feedback{margin-top:18px;border-radius:18px;padding:18px;background:#edf9ef;border:2px solid #7ec586}.feedback.bad{background:#fff0ed;border-color:#ef9a8d}.small{font-size:.86rem;color:var(--muted);line-height:1.5}.leader-row{display:flex;justify-content:space-between;padding:12px 0;border-bottom:1px solid var(--line)}.admin-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-top:12px}.check{display:flex;gap:8px;align-items:center;background:white;border:1px solid var(--line);border-radius:12px;padding:12px}.toast{position:fixed;left:50%;bottom:22px;transform:translateX(-50%);background:var(--ink);color:white;padding:14px 18px;border-radius:16px;box-shadow:0 10px 25px rgba(0,0,0,.2);z-index:20;text-align:center;font-weight:900}.top-actions{display:flex;gap:10px;align-items:center;flex-wrap:wrap}.music-btn{background:white;border:1.5px solid var(--line);border-radius:16px;padding:12px 16px;font-weight:900;cursor:pointer;color:var(--ink);font-family:inherit}.music-btn.on{background:#edf9ef;border-color:#7ec586;color:var(--green)}@media(max-width:850px){.char-grid,.dash,.choice-grid,.story-box{grid-template-columns:1fr}.grid-months{grid-template-columns:repeat(2,1fr)}.char-card{grid-template-columns:1fr;text-align:center}.char-card img{margin:auto}.top{align-items:flex-start;flex-direction:column}}
</style>
</head>
<body>
<div class="wrap">
  <div class="top"><div class="brand"><div class="logo">⏸</div><div><h1>Pause Before...</h1><div class="tag">A choose-your-path collaboration story</div></div></div><div class="top-actions"><button class="music-btn" id="musicBtn" onclick="toggleMusic()">🔇 Music Off</button><div class="pill" id="welcomePill">Welcome!</div></div></div>

  <div id="login" class="card hero"><h2>Enter the game</h2><p class="small">Your choices are saved on this browser. Return each month to continue the same story.</p><input id="nameInput" class="input" placeholder="Enter your name" onkeydown="if(event.key==='Enter')enterGame()"><button class="btn btn-green" onclick="enterGame()">Enter Game</button></div>

  <div id="app" class="hidden">
    <div class="tabs"><button class="tab active" onclick="tab('play')">🎮 Play</button><button class="tab" onclick="tab('leader')">🏆 Leaderboard</button><button class="tab admin-only hidden" onclick="tab('admin')">🔐 Admin</button></div>

    <section id="play" class="tabpage">
      <div id="characterSelect" class="card hero hidden"><h2>Who will you join on this journey?</h2><p>Your choices will shape their story, month by month.</p><div class="char-grid"><div class="char-card casey" onclick="chooseCharacter('casey')"><img src="data:image/png;base64,"><div><h3>Collaborative Casey</h3><p>Thoughtful, curious and caring. Casey wants to understand people and build stronger connections.</p><br><button class="btn btn-primary">Join Casey</button></div></div><div class="char-card charlie" onclick="chooseCharacter('charlie')"><img src="data:image/png;base64,"><div><h3>Collaborative Charlie</h3><p>Logical, dependable and reflective. Charlie believes in doing what is right for the team.</p><br><button class="btn btn-primary">Join Charlie</button></div></div></div><p class="small" style="margin-top:18px">Choose carefully. This journey follows one character throughout the series.</p></div>

      <div id="hub" class="hidden">
        <div class="card"><h2>🌱 Your Story Journey</h2><p class="small">Play each month. Your decisions shape the ending in December.</p><br><div class="grid-months" id="months"></div></div>
        <div class="dash"><div class="card"><h3>Your Journey So Far</h3><div class="profile"><img class="avatar" id="profileImg"><div><h2 id="profileChar">-</h2><p id="profileName" class="small">-</p><p class="small" id="profileQuote"></p></div></div></div><div class="card"><h3>Your Growth Path</h3><br><div class="bars" id="bars"></div><p class="small" style="margin-top:12px">These grow based on the choices you make.</p></div><div class="card"><h3>Stamps Collected</h3><br><div class="stamp-grid" id="stamps"></div></div></div>
      </div>

      <div id="story" class="card hidden"><div id="storyContent"></div></div>
    </section>

    <section id="leader" class="tabpage hidden"><div class="card"><h2>🌱 Collaboration Journey</h2><p class="small">Names only, so the focus stays on learning rather than chasing points.</p><div id="leaderList" style="margin-top:14px"></div></div></section>

    <section id="admin" class="tabpage hidden"><div class="card"><h2>🔐 Admin Control Center</h2><p class="small">Use <b>?admin=1</b> in the URL to view this panel. Unlock future months here on this browser.</p><div class="admin-grid" id="adminChecks"></div><br><button class="btn btn-green" onclick="saveAdminUnlocks()">Save Unlocks</button> <button class="btn btn-red" onclick="resetAll()">Clear All Game Records</button><div id="analytics" style="margin-top:20px"></div></div></section>
  </div>
</div>
<div id="toast" class="toast hidden"></div>
<script>
const CASEY_IMG="data:image/png;base64,"; const CHARLIE_IMG="data:image/png;base64,";
const IS_ADMIN=new URLSearchParams(location.search).get('admin')==='1';
const MONTHS=[
 {code:'JUN',title:'Pause Before Assuming',trait:'trust',stamp:'Assuming Handled'},
 {code:'JUL',title:'Pause Before Deciding',trait:'openMindedness',stamp:'Decision Checked'},
 {code:'AUG',title:'Pause Before Working Alone',trait:'curiosity',stamp:'Support Sought'},
 {code:'SEP',title:'Pause Before Reacting',trait:'respect',stamp:'Response Reframed'},
 {code:'OCT',title:'Pause Before Dismissing',trait:'openMindedness',stamp:'Idea Explored'},
 {code:'DEC',title:'The Ending',trait:'appreciation',stamp:'Journey Completed'}
];
const STORY={
 JUN:{title:'The quiet inbox',setup:'The team is preparing a collaboration campaign. A key colleague has not replied for two days. The deadline is near, and people are starting to wonder what is going on.',choices:[{label:'Assume they are ignoring the work and send a sharp follow-up.',effect:{trust:-8,respect:-4},tone:'bad',result:'The reply gets attention, but the tone lands badly. The colleague explains they were pulled into urgent work and now feels unfairly judged.'},{label:'Pause and check in warmly before jumping to conclusions.',effect:{trust:12,respect:6},tone:'good',result:'The colleague replies quickly and explains the delay. Because you assumed good intent, the relationship stays intact and the work moves forward.'}]},
 JUL:{title:'The fast decision',setup:'Because of what happened in June, the team is now reviewing how to work better. A decision is needed by end of day, but not everyone has the same information.',choices:[{label:'Go with the loudest suggestion so the team can move fast.',effect:{openMindedness:-8,curiosity:-4},tone:'bad',result:'The team moves quickly, but later realises one risk was missed. Speed helped, but the team did not fully consider other perspectives.'},{label:'Ask for the missing context and compare the trade-offs.',effect:{openMindedness:12,curiosity:6},tone:'good',result:'The team takes a little longer, but the decision is stronger. People feel different views were considered before moving ahead.'}]},
 AUG:{title:'The solo spiral',setup:'A tricky issue appears. Your character thinks they can solve it alone, but the clock is ticking and the task is getting heavier.',choices:[{label:'Keep pushing alone because asking for help feels slower.',effect:{curiosity:-7,trust:-3},tone:'bad',result:'Three hours disappear. The work improves slightly, but the team only finds out about the blocker late.'},{label:'Ask someone experienced for a quick sense-check.',effect:{curiosity:12,trust:5},tone:'good',result:'A five-minute conversation saves hours. The team spots a simpler route and everyone feels more included.'}]},
 SEP:{title:'The blunt message',setup:'A teammate sends a short, blunt message. It could be frustration, or it could just be a rushed reply. The team chat is watching.',choices:[{label:'Fire back with the same energy.',effect:{respect:-12,trust:-4},tone:'bad',result:'The chat goes quiet. The issue is unresolved, and the relationship takes a small hit.'},{label:'Pause, clarify intent and respond calmly.',effect:{respect:14,trust:5},tone:'good',result:'The teammate clarifies they were rushing between meetings. The conversation resets before it escalates.'}]},
 OCT:{title:'The familiar idea',setup:'A junior officer suggests an idea that sounds like something the team tried before. Some people are ready to dismiss it immediately.',choices:[{label:'Say “we tried this before” and move on.',effect:{openMindedness:-12,curiosity:-5},tone:'bad',result:'The idea disappears quickly. Later, the team realises the new version had one useful improvement they did not explore.'},{label:'Ask what is different this time and hear them out.',effect:{openMindedness:14,curiosity:7},tone:'good',result:'The team discovers a small twist that makes the idea more workable. The junior officer feels encouraged to contribute again.'}]},
 DEC:{title:'The final reflection',setup:'The campaign wraps. Casey and Charlie look back at how the team handled assumptions, decisions, support, responses and new ideas.',choices:[{label:'Jump straight into the next project.',effect:{appreciation:-10,respect:-4},tone:'bad',result:'The team completes the work, but some lessons and appreciation are lost.'},{label:'Pause to thank the team and capture what worked.',effect:{appreciation:14,respect:6,trust:4},tone:'good',result:'The team ends stronger. The lessons are captured, people feel seen, and the next project starts on better ground.'}]}
};
let state={name:'',character:'',scores:{openMindedness:50,curiosity:50,appreciation:50,trust:50,respect:50},completed:{},current:null,choice:null};
function normaliseScores(){
  const old=state.scores||{};
  state.scores={
    openMindedness: old.openMindedness ?? old.collaboration ?? 50,
    curiosity: old.curiosity ?? 50,
    appreciation: old.appreciation ?? 50,
    trust: old.trust ?? 50,
    respect: old.respect ?? 50
  };
}
function defaultUnlocks(){return ['JUN'];}
function released(){return JSON.parse(localStorage.getItem('pb_released')||JSON.stringify(defaultUnlocks()));}
function playerKey(n){return 'pb_player_'+(n||'player').toLowerCase().replace(/[^a-z0-9]+/g,'_')}
function save(){if(!state.name)return;localStorage.setItem(playerKey(state.name),JSON.stringify(state));localStorage.setItem('pb_active',state.name);syncBoard();renderAll();}
function load(n){const s=localStorage.getItem(playerKey(n)); if(s){state=JSON.parse(s); normaliseScores();}else{state={name:n,character:'',scores:{openMindedness:50,curiosity:50,appreciation:50,trust:50,respect:50},completed:{},current:null,choice:null}; normaliseScores();}}

let musicOn=localStorage.getItem('pb_music_on')==='1';
let musicCtx=null;
let musicTimer=null;
let musicStep=0;
const MUSIC_NOTES=[261.63,329.63,392.00,493.88,392.00,329.63,293.66,349.23,440.00,392.00,329.63,293.66];
function updateMusicButton(){const b=document.getElementById('musicBtn');if(!b)return;b.textContent=musicOn?'🔊 Music On':'🔇 Music Off';b.classList.toggle('on',musicOn)}
function tone(freq,start,duration,type='sine',vol=.025){if(!musicCtx)return;const o=musicCtx.createOscillator();const g=musicCtx.createGain();o.type=type;o.frequency.setValueAtTime(freq,start);g.gain.setValueAtTime(0.0001,start);g.gain.linearRampToValueAtTime(vol,start+.03);g.gain.exponentialRampToValueAtTime(0.0001,start+duration);o.connect(g);g.connect(musicCtx.destination);o.start(start);o.stop(start+duration+.02)}
function playMusicStep(){if(!musicOn||!musicCtx)return;const now=musicCtx.currentTime;const note=MUSIC_NOTES[musicStep%MUSIC_NOTES.length];tone(note,now,.38,'sine',.022);if(musicStep%4===0)tone(note/2,now,.75,'triangle',.018);if(musicStep%6===0)tone(note*2,now+.05,.18,'sine',.012);musicStep++}
function startMusic(){if(!musicOn)return;try{const AudioContext=window.AudioContext||window.webkitAudioContext;if(!AudioContext)return;if(!musicCtx)musicCtx=new AudioContext();if(musicCtx.state==='suspended')musicCtx.resume();if(musicTimer)return;playMusicStep();musicTimer=setInterval(playMusicStep,520)}catch(e){}}
function stopMusic(){if(musicTimer){clearInterval(musicTimer);musicTimer=null}}
function toggleMusic(){musicOn=!musicOn;localStorage.setItem('pb_music_on',musicOn?'1':'0');updateMusicButton();if(musicOn){startMusic();toast('Cozy background music on 🎧')}else{stopMusic();toast('Music off 🔇')}}
function choiceSound(kind='soft'){try{const AudioContext=window.AudioContext||window.webkitAudioContext;if(!AudioContext)return;const ctx=musicCtx||new AudioContext();const now=ctx.currentTime;const seq=kind==='stamp'?[523,659,784]:kind==='unlock'?[392,523]:kind==='oops'?[220,196]:[440];seq.forEach((f,i)=>{const o=ctx.createOscillator();const g=ctx.createGain();o.type='sine';o.frequency.setValueAtTime(f,now+i*.08);g.gain.setValueAtTime(.0001,now+i*.08);g.gain.linearRampToValueAtTime(.05,now+i*.08+.01);g.gain.exponentialRampToValueAtTime(.0001,now+i*.08+.12);o.connect(g);g.connect(ctx.destination);o.start(now+i*.08);o.stop(now+i*.08+.13)})}catch(e){}}

function init(){updateMusicButton();if(IS_ADMIN)document.querySelectorAll('.admin-only').forEach(x=>x.classList.remove('hidden')); const active=localStorage.getItem('pb_active'); if(active){load(active);showApp()} else if(IS_ADMIN){state.name='Admin';showApp();tab('admin')} renderAll();}
function enterGame(){const n=document.getElementById('nameInput').value.trim(); if(!n)return alert('Please enter your name.'); load(n); showApp(); save(); startMusic();}
function showApp(){document.getElementById('login').classList.add('hidden');document.getElementById('app').classList.remove('hidden');document.getElementById('welcomePill').textContent='Welcome, '+state.name+'!'; if(!state.character){document.getElementById('characterSelect').classList.remove('hidden');document.getElementById('hub').classList.add('hidden')}else{document.getElementById('characterSelect').classList.add('hidden');document.getElementById('hub').classList.remove('hidden')}}
function chooseCharacter(c){if(state.character)return;state.character=c;choiceSound('unlock');toast('You joined '+(c==='casey'?'Collaborative Casey':'Collaborative Charlie')+'!');save();showApp();startMusic();}
function isDone(i){return !!state.completed[MONTHS[i].code]}
function canPlay(i){const code=MONTHS[i].code; return released().includes(code) && (i===0 || isDone(i-1));}
function renderMonths(){const el=document.getElementById('months'); if(!el)return; el.innerHTML=MONTHS.map((m,i)=>{let cls=isDone(i)?'done':canPlay(i)?'available':'locked';let badge=isDone(i)?'COMPLETED':canPlay(i)?'AVAILABLE':released().includes(m.code)?'LOCKED':'COMING SOON';let img=(i%2===0?CASEY_IMG:CHARLIE_IMG); if(m.code==='DEC')img=state.character==='charlie'?CHARLIE_IMG:CASEY_IMG;return `<div class="month-card ${cls}" onclick="startMonth(${i})"><div class="badge">${badge}</div><div class="month-big">${m.code}</div><p>${m.title}</p>${cls==='locked'?'<div style="font-size:2rem;margin-top:30px">🔒</div>':`<img src="${img}"><br><button class="btn ${isDone(i)?'btn-soft':'btn-green'}">${isDone(i)?'View':'Play Now'}</button>`}</div>`}).join('')}
function startMonth(i){if(!state.character)return; if(isDone(i)){showSummary(MONTHS[i].code);return} if(!canPlay(i)){return alert(released().includes(MONTHS[i].code)?'Complete the previous month first.':'This chapter has not been unlocked by admin yet.')} state.current=MONTHS[i].code;state.choice=null;document.getElementById('hub').classList.add('hidden');document.getElementById('story').classList.remove('hidden');renderStory();}
function renderStory(){const s=STORY[state.current];const m=MONTHS.find(x=>x.code===state.current);const img=state.character==='charlie'?CHARLIE_IMG:CASEY_IMG;let past=Object.keys(state.completed).length;let html=`<div class="story-head"><button class="btn btn-soft" onclick="backHub()">← Back</button><b>${m.code}: ${m.title}</b></div><div class="story-box"><img src="${img}"><div><div class="scene-title">${s.title}</div><p class="scene-text">${addContinuity(s.setup,past)}</p></div></div>`; if(state.choice===null){html+=`<div class="choice-grid">${s.choices.map((c,i)=>`<button class="choice" onclick="choosePath(${i})"><b>${i===0?'A':'B'}. ${c.label}</b><span class="small">Choose this path</span></button>`).join('')}</div>`} else {const c=s.choices[state.choice];html+=`<div class="feedback ${c.tone==='bad'?'bad':''}"><b>${c.tone==='bad'?'⚡ A fast reaction changed the mood':'🌱 A thoughtful pause helped the team'}</b><p style="margin-top:8px">${c.result}</p></div><br><button class="btn btn-green" onclick="completeMonth()">Earn ${m.code} Stamp →</button>`} document.getElementById('storyContent').innerHTML=html}
function addContinuity(text,past){if(!past)return text; const good=Object.values(state.completed).filter(x=>x.tone==='good').length; return text + (good>=past/2?' Your earlier pauses have built some trust in the team.':' Some earlier choices left the team with a little tension, so this moment matters even more.');}
function choosePath(i){state.choice=i;choiceSound(i===0?'oops':'soft');renderStory();}
function completeMonth(){choiceSound('stamp');const code=state.current;const c=STORY[code].choices[state.choice];for(const [k,v] of Object.entries(c.effect)){state.scores[k]=Math.max(0,Math.min(100,state.scores[k]+v));}state.completed[code]={choice:state.choice,tone:c.tone,result:c.result};state.current=null;state.choice=null;toast(code==='DEC'?endingText():'Stamp earned! Come back when the next chapter unlocks.');backHub();save();}
function showSummary(code){
  const data=state.completed[code];
  const s=STORY[code];
  const m=MONTHS.find(x=>x.code===code);
  const selected=data.choice;

  function effectText(effect){
    return Object.entries(effect).map(([k,v])=>{
      const label={openMindedness:'Open-mindedness',curiosity:'Curiosity',appreciation:'Appreciation',trust:'Trust',respect:'Respect'}[k]||k;
      const sign=v>0?'+':'';
      return `${label} ${sign}${v}`;
    }).join(' · ');
  }

  const choicesHtml=s.choices.map((choice,i)=>{
    const isSelected=i===selected;
    const letter=i===0?'A':'B';
    const toneLabel=choice.tone==='bad'?'Fast reaction path':'Thoughtful pause path';
    const border=isSelected?'var(--green)':'var(--line)';
    const bg=isSelected?'#f4fbf2':'white';
    return `
      <div style="border:2px solid ${border}; background:${bg}; border-radius:18px; padding:18px; margin-top:14px;">
        <div style="display:flex; justify-content:space-between; gap:10px; align-items:flex-start; margin-bottom:8px;">
          <b>${letter}. ${choice.label}</b>
          ${isSelected?'<span style="background:var(--green); color:white; border-radius:999px; padding:5px 10px; font-size:.75rem; font-weight:900; white-space:nowrap;">YOUR PICK</span>':''}
        </div>
        <p class="small"><b>Path:</b> ${toneLabel}</p>
        <p style="margin-top:10px; line-height:1.55;"><b>Rationale:</b> ${choice.result}</p>
        <p class="small" style="margin-top:10px;"><b>Impact on growth path:</b> ${effectText(choice.effect)}</p>
      </div>
    `;
  }).join('');

  document.getElementById('hub').classList.add('hidden');
  document.getElementById('story').classList.remove('hidden');
  document.getElementById('storyContent').innerHTML=`
    <button class="btn btn-soft" onclick="backHub()">← Back</button>
    <h2 style="margin:18px 0 6px">${code} Completed</h2>
    <p class="small" style="margin-bottom:14px;">${m.title} · Here’s what you chose, what the other path could have led to, and why it matters.</p>
    ${choicesHtml}
  `
}
function backHub(){document.getElementById('story').classList.add('hidden');document.getElementById('hub').classList.remove('hidden');renderAll();}
function renderBars(){const labels={openMindedness:'🧠 Open-mindedness',curiosity:'🔎 Curiosity',appreciation:'🌻 Appreciation',trust:'❤️ Trust',respect:'⭐ Respect'};document.getElementById('bars').innerHTML=Object.entries(state.scores).map(([k,v])=>`<div class="bar-row"><div>${labels[k]||k}</div><div class="track"><div class="fill" style="width:${v}%"></div></div><b>${v}</b></div>`).join('')}
function renderProfile(){if(!state.character)return;document.getElementById('profileImg').src=state.character==='charlie'?CHARLIE_IMG:CASEY_IMG;document.getElementById('profileChar').textContent=state.character==='charlie'?'Charlie':'Casey';document.getElementById('profileName').textContent='Player: '+state.name;document.getElementById('profileQuote').textContent='“Every pause is a chance to grow closer.”'}
function renderStamps(){document.getElementById('stamps').innerHTML=MONTHS.map(m=>`<div class="stamp ${state.completed[m.code]?'got':''}">${state.completed[m.code]?m.code+'<br>'+m.stamp:'—'}</div>`).join('')}
function syncBoard(){let b=JSON.parse(localStorage.getItem('pb_board')||'[]');let score=Object.values(state.scores).reduce((a,b)=>a+b,0)+Object.keys(state.completed).length*25;let idx=b.findIndex(x=>x.name===state.name);let row={name:state.name,character:state.character,score,stamps:Object.keys(state.completed).length};if(idx>=0)b[idx]=row;else b.push(row);localStorage.setItem('pb_board',JSON.stringify(b));}
function renderLeader(){let b=JSON.parse(localStorage.getItem('pb_board')||'[]').sort((a,b)=>b.score-a.score).slice(0,10);document.getElementById('leaderList').innerHTML=b.map((p,i)=>`<div class="leader-row"><span><b>${i+1}. ${p.name}</b></span><span>${p.stamps||0} stamp${(p.stamps||0)===1?'':'s'}</span></div>`).join('')||'<p class="small">No players yet.</p>'}
function renderAdmin(){if(!IS_ADMIN)return;let rel=released();document.getElementById('adminChecks').innerHTML=MONTHS.map(m=>`<label class="check"><input type="checkbox" value="${m.code}" ${rel.includes(m.code)?'checked':''}> ${m.code} - ${m.title}</label>`).join('');let b=JSON.parse(localStorage.getItem('pb_board')||'[]');document.getElementById('analytics').innerHTML=`<h3>Analytics</h3><p>Participants: <b>${b.length}</b></p><p>Stamp Earners: <b>${b.filter(x=>x.stamps>0).length}</b></p><p>Released Months: <b>${rel.join(', ')}</b></p>`}
function saveAdminUnlocks(){let arr=[...document.querySelectorAll('#adminChecks input:checked')].map(x=>x.value);localStorage.setItem('pb_released',JSON.stringify(arr));choiceSound('unlock');toast('Unlocks saved: '+arr.join(', '));renderAll();}
function resetAll(){if(!confirm('Clear ALL records on this browser?'))return;localStorage.clear();location.reload();}
function endingText(){let avg=Object.values(state.scores).reduce((a,b)=>a+b,0)/5; if(avg>=75)return 'Final ending: Collaborative Champion 🌟'; if(avg>=60)return 'Final ending: Steady Team Builder 🤝'; return 'Final ending: Future Pauser 🌱';}
function tab(id){document.querySelectorAll('.tabpage').forEach(x=>x.classList.add('hidden'));document.querySelectorAll('.tab').forEach(x=>x.classList.remove('active'));document.getElementById(id).classList.remove('hidden');event?.target?.classList.add('active');if(id==='leader')renderLeader();if(id==='admin')renderAdmin();}
function toast(msg){let t=document.getElementById('toast');t.innerHTML=msg;t.classList.remove('hidden');setTimeout(()=>t.classList.add('hidden'),3600)}
function renderAll(){renderMonths();renderBars();renderProfile();renderStamps();renderLeader();renderAdmin();}
init();
</script>
</body>
</html>
